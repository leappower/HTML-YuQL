# Server Configuration
PORT=3000
NODE_ENV=development

# Security
SESSION_SECRET=your-secret-key-here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Compression
COMPRESSION_LEVEL=6

# Cache
CACHE_MAX_AGE=86400000

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# Health Check
HEALTH_CHECK_ENABLED=true

# ─────────────────────────────────────────────
# 翻译 API（运行 npm run translate:products 前必须设置）
# ─────────────────────────────────────────────

# 引擎 A：中科网 Qwen3-30B
# 申请地址：https://www.scnet.cn/ui/llm/
# 支持全部目标语言（含 Hebrew/Malay）
#
# 多 Key 轮转（推荐）：填写 SCNET_API_KEY_1, _2, _3...，全局并发 = Key数 × 20
# 单 Key 兼容：只填 SCNET_API_KEY（系统自动识别）
SCNET_API_KEY_1=sk-xxxxxxxxxxxxxxxxxxxxxxxx
SCNET_API_KEY_2=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# SCNET_API_KEY_3=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 引擎 B：硅基流动 Hunyuan-MT-7B（腾讯混元专用翻译模型）
# 申请地址：https://cloud.siliconflow.cn/account/ak
# 模型文档：https://cloud.siliconflow.cn/models?target=tencent/Hunyuan-MT-7B
# ⚠️  不支持 Hebrew(he) 和 Malay(ms)，这两种语言自动降级到 scnet
#
# 多 Key 轮转（推荐）：填写 SILICONFLOW_API_KEY_1, _2...，全局并发 = Key数 × 10
# 单 Key 兼容：只填 SILICONFLOW_API_KEY
SILICONFLOW_API_KEY_1=sk-xxxxxxxxxxxxxxxxxxxxxxxx
SILICONFLOW_API_KEY_2=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# SILICONFLOW_API_KEY_3=sk-xxxxxxxxxxxxxxxxxxxxxxxx
