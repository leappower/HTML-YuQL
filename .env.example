# Server Configuration
PORT=3000
NODE_ENV=development

# Security
SESSION_SECRET=your-secret-key-here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Compression
COMPRESSION_LEVEL=6

# Cache
CACHE_MAX_AGE=86400000

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# Health Check
HEALTH_CHECK_ENABLED=true